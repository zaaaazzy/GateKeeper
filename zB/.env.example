# ============================================
# Gatekeeper - Umgebungsvariablen
# ============================================
# Kopiere diese Datei nach .env und fülle die Werte aus
# cp .env.example .env

# ============================================
# Node.js Umgebung
# ============================================
# Werte: development, production
# In Production werden secure Cookies aktiviert (HTTPS erforderlich)
NODE_ENV=development

# ============================================
# Server-Konfiguration
# ============================================
# Port auf dem die App läuft
PORT=3000

# ============================================
# Datenbank-Konfiguration
# ============================================
# MySQL/MariaDB Verbindungsparameter
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=dein_starkes_passwort_hier
DB_NAME=provisioning
DB_PORT=3306

# Connection Pool Limit (wie viele gleichzeitige DB-Verbindungen)
DB_CONN_LIMIT=10

# ============================================
# Session-Sicherheit
# ============================================
# WICHTIG: Generiere einen sicheren, zufälligen String!
# Generieren mit: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
# 
# ⚠️  NIEMALS den Beispiel-Wert in Production verwenden!
# ⚠️  Session-Secret IMMER geheim halten!
SESSION_SECRET=generiere_hier_einen_sehr_langen_zufaelligen_string_mit_mindestens_64_zeichen

# ============================================
# Sicherheits-Einstellungen (Optional)
# ============================================
# Überschreibe Rate-Limiting-Werte (Standard siehe middleware/rateLimiter.js)
# LOGIN_RATE_MAX=5
# LOGIN_RATE_WINDOW=900000
# API_RATE_MAX=100
# API_RATE_WINDOW=900000

# ============================================
# Logging (Optional)
# ============================================
# LOG_LEVEL=info
# LOG_FILE=logs/app.log

# ============================================
# SMTP für Email-Benachrichtigungen (Zukünftig)
# ============================================
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=noreply@example.com
# SMTP_PASSWORD=app_password
# SMTP_FROM=Gatekeeper <noreply@example.com>

# ============================================
# Hinweise zur Sicherheit
# ============================================
# 1. Diese Datei (.env) NIEMALS in Git committen!
# 2. Berechtigungen einschränken: chmod 600 .env
# 3. In Production HTTPS verwenden (NODE_ENV=production)
# 4. SESSION_SECRET regelmäßig rotieren
# 5. Starke DB-Passwörter verwenden (min. 16 Zeichen)
# 6. DB-User nur notwendige Rechte geben (keine GRANT/ALTER)
