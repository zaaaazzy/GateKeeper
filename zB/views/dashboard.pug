extends layout

block content
  .list-container
    .list-header
      h1.page-title Dashboard
      .traffic-control
        span.traffic-label Traffic ein/aus
        .traffic-toggle-wrapper
          input#trafficToggle(type='checkbox', checked=!trafficBlocked)
          label.toggle-switch(for='trafficToggle')
            span.toggle-slider
    
    if success
      .success= success
    if error
      .error= error
    
    // VLAN Info Card
    if userVlan
      .vlan-card
        .vlan-card-header
          h3 Ihr aktuelles VLAN
          span.vlan-badge= userVlan.name
        .vlan-card-details
          .vlan-card-item
            p.vlan-label Netzwerk
            p.vlan-value= userVlan.ip
          .vlan-card-item
            p.vlan-label Raum
            p.vlan-value= userVlan.room_name || '-'
    
    // Whitelist anzeigen
    if userVlan
      .list-header.whitelist-header
        h2.page-title Meine Whitelists
        .actions
          a.btn.btn-icon-only(href='/secured/whitelist/add', title='Neue Whitelist hinzufügen')
            span.btn-icon +
      
      if whitelists && whitelists.length > 0
        .table-wrapper
          table.vlans
            thead
              tr
                th Name
                th URL
                th Start
                th Ende
                th VLAN
                th Aktionen
            tbody
              each whitelist in whitelists
                tr(data-whitelist-id=whitelist.id)
                  td= whitelist.name
                  td
                    a(href=whitelist.url, target='_blank', style='color: #1fa667; text-decoration: none;')= whitelist.url
                  td= whitelist.start_display || '-'
                  td= whitelist.end_display || '-'
                  td= whitelist.vlan_name || userVlan.name
                  td.action-buttons
                    a.btn.btn-small.btn-icon-only(href=`/secured/whitelist/edit/${whitelist.id}`, title='Bearbeiten')
                      span.btn-icon ✎
                    button.btn.btn-small.btn-danger.btn-icon-only(type='button', data-delete-whitelist=whitelist.id, data-whitelist-name=whitelist.name, title='Löschen')
                      span.btn-icon ✕
      else
        p(style='color: #6c757d; font-style: italic;') Noch keine Whitelists vorhanden. Fügen Sie Ihre erste Whitelist oben hinzu.
    else
      p.error Kein VLAN verfügbar. Bitte kontaktieren Sie den Administrator.

block scripts
  script.
    const csrfToken = '#{csrfToken}';
    
    // Traffic Toggle
    const trafficToggle = document.getElementById('trafficToggle');
    if (trafficToggle) {
      trafficToggle.addEventListener('change', async (e) => {
        try {
          const response = await fetch('/auth/dashboard/toggle-traffic', {
            method: 'POST',
            headers: {
              'Content-Type': 'application/json',
              'X-CSRF-Token': csrfToken
            }
          });
          
          if (response.ok) {
            window.location.reload();
          } else {
            // Revert checkbox state on error
            e.target.checked = !e.target.checked;
            alert('Fehler beim Umschalten des Traffic-Status');
          }
        } catch (err) {
          console.error('Fehler:', err);
          // Revert checkbox state on error
          e.target.checked = !e.target.checked;
          alert('Fehler beim Umschalten des Traffic-Status');
        }
      });
    }
    
    // Delete-Funktion für Whitelist
    function initDeleteButtons() {
      const deleteButtons = document.querySelectorAll('[data-delete-whitelist]');
      
      deleteButtons.forEach(btn => {
        btn.addEventListener('click', () => {
          const whitelistId = btn.getAttribute('data-delete-whitelist');
          const whitelistName = btn.getAttribute('data-whitelist-name');
          
          if (typeof Modal === 'undefined') {
            console.error('Modal ist nicht verfügbar');
            alert('Fehler: Modal-System nicht geladen');
            return;
          }
          
          Modal.open({
            title: 'Whitelist-Eintrag löschen',
            message: `Möchten Sie den Whitelist-Eintrag "${whitelistName}" wirklich löschen? Diese Aktion kann nicht rückgängig gemacht werden.`,
            confirmText: 'Löschen',
            cancelText: 'Abbrechen',
            danger: true,
            onConfirm: async () => {
              try {
                const response = await fetch(`/auth/dashboard/delete-whitelist/${whitelistId}`, {
                  method: 'POST',
                  headers: {
                    'Content-Type': 'application/json',
                    'X-CSRF-Token': csrfToken
                  }
                });
                
                if (response.ok) {
                  const row = document.querySelector(`tr[data-whitelist-id="${whitelistId}"]`);
                  if (row) {
                    row.style.opacity = '0';
                    setTimeout(() => row.remove(), 300);
                  }
                } else {
                  alert('Fehler beim Löschen des Whitelist-Eintrags');
                }
              } catch (err) {
                console.error('Fehler:', err);
                alert('Fehler beim Löschen des Whitelist-Eintrags');
              }
            }
          });
        });
      });
    }
    
    // Initialisiere nach DOM-Load oder sofort wenn bereits geladen
    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', initDeleteButtons);
    } else {
      initDeleteButtons();
    }
