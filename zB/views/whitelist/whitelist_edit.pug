extends ../layout

block content
  .edit-form-container
    .card.edit-card
      h1.form-title Whitelist bearbeiten
      
      if error
        p.error= error
      if success
        p.success= success
      
      form.user-edit-form(method='post', action=`/secured/whitelist/edit/${whitelist.id}`)
        input(type='hidden', name='_csrf', value=csrfToken)
        if user && user.role === 1
          .form-row
            label.form-label(for='user_id') Benutzer
            .select-wrapper
              select.form-select(name='user_id', id='user_id', required)
                each u in users
                  option(value=u.id, selected=(whitelist.user_id == u.id))= u.email
        
        .form-row
          label.form-label(for='name') Name
          input.form-input(type='text', name='name', id='name', value=whitelist.name, required)
        
        .form-row
          label.form-label(for='url') URL
          input.form-input(type='url', name='url', id='url', value=whitelist.url, required)
        
        if user && user.role === 1
          .form-row
            label.form-label(for='vlan_id') VLAN
            .select-wrapper
              select.form-select(name='vlan_id', id='vlan_id', required)
                each vlan in vlans
                  option(value=vlan.id, selected=(whitelist.vlan_id == vlan.id))= vlan.name
        
        .form-row
          label.form-label(for='start') Start (optional)
          input.form-input(type='datetime-local', name='start', id='start', value=whitelist.start || '')
        
        .form-row
          label.form-label(for='end') Ende (optional)
          input.form-input(type='datetime-local', name='end', id='end', value=whitelist.end || '')
        
        .form-row
          label.form-label(for='rythm') Rhythmus (optional)
          .select-wrapper
            select.form-select(name='rythm', id='rythm')
                option(value='', selected=!whitelist.rythm) -- Bitte wählen --
                option(value='1', selected=(whitelist.rythm == 1)) 1
                option(value='2', selected=(whitelist.rythm == 2)) 2
                option(value='3', selected=(whitelist.rythm == 3)) 3
                option(value='4', selected=(whitelist.rythm == 4)) 4
        
        .form-row
          label.form-label(for='unit') Einheit (optional)
          .select-wrapper
            select.form-select(name='unit', id='unit')
                option(value='', selected=!whitelist.unit) -- Bitte wählen --
                option(value='täglich', selected=(whitelist.unit === 'täglich')) Täglich
                option(value='wöchentlich', selected=(whitelist.unit === 'wöchentlich')) Wöchentlich
  
        
        .form-actions
          button.btn.btn-icon-only(type='submit', title='Speichern')
            span.btn-icon ✓
          if user && user.role === 1
            a.btn.btn-secondary.btn-icon-only(href='/secured/whitelist', title='Abbrechen')
              span.btn-icon ←
          else
            a.btn.btn-secondary.btn-icon-only(href='/auth/dashboard', title='Abbrechen')
              span.btn-icon ←
