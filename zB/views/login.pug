extends layout

block content
  .login-container
    .card
      h1.login-title Login
      if error
        .error= error
      form.login-form(method='post', action='/auth/login')
        input(type='hidden', name='_csrf', value=csrfToken)
        .form-row
          label.form-label(for='email') Email
          input.form-input(type='email', name='email', id='email', required, placeholder='you@example.com', autocomplete='email')
        .form-row
          label.form-label(for='password') Kennwort
          input.form-input(type='password', name='password', id='password', required, placeholder='••••••••', autocomplete='current-password')
        .form-actions
          button.btn(type='submit') Anmelden
        .hint
          a(href='#') Passwort vergessen?
